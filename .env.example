# =============================================================================
# LinkedIn Auto Job Applier - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control!

# -----------------------------------------------------------------------------
# Website API Integration (Whitebox Learning Dashboard)
# -----------------------------------------------------------------------------
WBL_API_URL=https://api.whitebox-learning.com/api

# Option 1: Use email/password - bot will auto-authenticate and cache token
API_EMAIL=your_email@example.com
API_PASSWORD=your_password
API_OPERATOR_NAME=Sunil Poli
SECRET_KEY=your_secret_key_here


# Option 2: Use pre-generated API token directly
# If you have a token, you can set it here (token will be cached after first use)
WEBSITE_API_TOKEN=your_api_token_here

# -----------------------------------------------------------------------------
# LinkedIn Credentials
# -----------------------------------------------------------------------------
# NOTE: It's recommended to use browser session instead of storing credentials
LINKEDIN_USERNAME=your_email@example.com
LINKEDIN_PASSWORD=your_password_here

# -----------------------------------------------------------------------------
# AI Provider Settings
# -----------------------------------------------------------------------------
# Choose provider: openai, deepseek, or gemini
AI_PROVIDER=gemini

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/
OPENAI_MODEL=gpt-3.5-turbo

# DeepSeek Configuration (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Gemini Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Bot Settings
# -----------------------------------------------------------------------------
USE_AI=false
STREAM_OUTPUT=false
SHOW_AI_ERROR_ALERTS=false
